<tr><td>Business Resilience</td><td>cr39e_businessresilience</td><td>Choice (Low, Medium, High)</td><td>Yes</td><td></td></tr>
<tr><td>Business Agility</td><td>cr39e_businessagility</td><td>Choice (Low, Medium, High)</td><td>Yes</td><td></td></tr>
